{
  "name": "@laoshuikaixue/cloudmusic-cli",
  "version": "0.1.0",
  "description": "A terminal-first NetEase Cloud Music player with spectrum visualization and AI tool support.",
  "keywords": [
    "netease-cloud-music",
    "cli",
    "tui",
    "music-player",
    "mcp"
  ],
  "author": "laoshuikaixue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laoshuikaixue/cloudmusic-cli.git"
  },
  "homepage": "https://github.com/laoshuikaixue/cloudmusic-cli#readme",
  "bugs": {
    "url": "https://github.com/laoshuikaixue/cloudmusic-cli/issues"
  },
  "type": "module",
  "bin": {
    "ncm": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "pnpm build:js && pnpm build:native",
    "build:js": "tsup src/cli.ts --format esm --platform node --target node22 --sourcemap",
    "build:native": "node scripts/build-native.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.29.3",
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neteasecloudmusicapienhanced/api": "4.36.1",
    "commander": "^14.0.3",
    "env-paths": "^3.0.0",
    "fast-xml-parser": "^5.10.0",
    "ink": "^6.8.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.20.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.7"
  }
}
